{
  "id": "agentline",
  "name": "AgentLine",
  "description": "Secure agent-to-agent messaging via the AgentLine A2A protocol (Ed25519 signed envelopes)",
  "version": "0.1.13",
  "channels": ["agentline"],
  "skills": ["./skills"],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "hubUrl": {
        "type": "string",
        "description": "AgentLine Hub URL"
      },
      "agentId": {
        "type": "string",
        "description": "Agent ID (ag_xxxxxxxxxxxx)"
      },
      "keyId": {
        "type": "string",
        "description": "Signing key ID (k_xxxx)"
      },
      "privateKey": {
        "type": "string",
        "description": "Ed25519 private key seed (base64)"
      },
      "publicKey": {
        "type": "string",
        "description": "Ed25519 public key (base64)"
      },
      "deliveryMode": {
        "type": "string",
        "enum": ["websocket", "polling"],
        "default": "websocket"
      },
      "pollIntervalMs": {
        "type": "number",
        "default": 5000
      },
      "allowFrom": {
        "type": "array",
        "items": { "type": "string" }
      }
    }
  },
  "uiHints": {
    "privateKey": { "sensitive": true }
  }
}
