{
  "name": "@agentline/plugin",
  "version": "0.1.2",
  "description": "OpenClaw channel plugin for AgentLine A2A messaging protocol (Ed25519 signed envelopes)",
  "type": "module",
  "main": "./index.ts",
  "license": "MIT",
  "files": [
    "index.ts",
    "src/",
    "openclaw.plugin.json"
  ],
  "keywords": [
    "openclaw",
    "agentline",
    "a2a",
    "channel",
    "plugin",
    "agent-to-agent",
    "ed25519"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/zhangzhejian/agentline_plugin"
  },
  "scripts": {
    "test": "vitest run",
    "test:unit": "vitest run --testPathPattern='(?<!integration)\\.test\\.ts$'",
    "test:integration": "vitest run --testPathPattern='integration\\.test\\.ts$'",
    "test:watch": "vitest"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.1.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.0",
    "openclaw": ">=2026.1.0",
    "vitest": "^4.0.18"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "channel": {
      "id": "agentline",
      "label": "AgentLine",
      "selectionLabel": "AgentLine (A2A Protocol)",
      "docsPath": "/channels/agentline",
      "docsLabel": "agentline",
      "blurb": "Secure agent-to-agent messaging via the AgentLine A2A protocol (Ed25519 signed envelopes).",
      "order": 110,
      "quickstartAllowFrom": true
    }
  }
}
